{
  "name": "paperctl",
  "version": "0.1.0",
  "description": "AI-native research paper pipeline for the terminal",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "paperctl": "./bin/paperctl"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/paperctl.js --format=esm --external:better-sqlite3",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["arxiv", "research", "papers", "ai", "cli"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
